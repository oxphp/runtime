{
    "name": "oxphp/runtime",
    "description": "OxPHP runtime adapter — run Symfony, Laravel and PSR-15 apps on the OxPHP server, in traditional and worker mode.",
    "license": "MIT",
    "type": "library",
    "keywords": ["oxphp", "runtime", "symfony-runtime", "psr-15", "laravel", "worker"],
    "require": {
        "php": ">=8.4",
        "symfony/runtime": "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.58",
        "symfony/http-kernel": "^6.4 || ^7.0",
        "illuminate/contracts": "^11.0",
        "nyholm/psr7": "^1.8",
        "psr/http-server-handler": "^1.0"
    },
    "suggest": {
        "symfony/http-kernel":  "To run Symfony HttpKernel applications",
        "illuminate/contracts": "To run Laravel applications",
        "nyholm/psr7":          "Recommended PSR-17 factory for PSR-15 handlers",
        "guzzlehttp/psr7":      "Alternative PSR-17 factory",
        "httpsoft/http-message": "Alternative PSR-17 factory",
        "laminas/laminas-diactoros": "Alternative PSR-17 factory"
    },
    "autoload": {
        "psr-4": { "OxPHP\\Runtime\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "OxPHP\\Runtime\\Tests\\": "tests/" }
    },
    "extra": {
        "runtime": { "class": "OxPHP\\Runtime\\Runtime" }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true
        }
    }
}
